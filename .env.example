# Telegram bot token from @BotFather
BOT_TOKEN=

# Random 32+ char string used as the URL path and as the Telegram secret token
WEBHOOK_SECRET=

# Public URL Render assigns to the service, e.g. https://nomore-coach-potato.onrender.com
# Only required when MODE=webhook
PUBLIC_URL=

# Supabase pooled connection string (port 6543, ?sslmode=require)
DATABASE_URL=

# Comma-separated Telegram user IDs allowed to talk to the bot
ALLOWED_CHAT_IDS=

# IANA timezone for displaying times
TIMEZONE=Europe/Madrid

# poll (local dev, no public URL needed) or webhook (Render)
MODE=poll

# Port for the webhook server. Render injects $PORT automatically.
PORT=8080
